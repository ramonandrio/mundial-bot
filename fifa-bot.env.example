# Copia este fichero a fifa-bot.env y rellena tus valores.
# fifa-bot.env NO debe subirse a ningún repo (contiene secretos).

# Qué script ejecutar:
#   fifa-bot-telegram.py   -> Telegram (recomendado para iterar; sin riesgo de baneo)
#   fifa-bot-anthropic.py  -> WhatsApp vía bridge local, LLM Anthropic
#   fifa-bot-openai.py     -> WhatsApp vía bridge local, LLM OpenAI
BOT_SCRIPT=fifa-bot-telegram.py

# --- Telegram (si BOT_SCRIPT=fifa-bot-telegram.py) ---
# Uno o varios destinos separados por comas: tu chat_id, el de otra persona, o @canal.
TELEGRAM_CHAT_ID=TU_CHAT_ID_O_@canal
# TELEGRAM_BOT_TOKEN=...     # token de @BotFather (en el mini ponlo aquí)

# --- WhatsApp (si BOT_SCRIPT=fifa-bot-anthropic.py / openai.py) ---
# FIFA_BOT_RECIPIENT=TU_NUMERO    # número con prefijo de país, sin "+", o JID de grupo

# --- LLM ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
# FIFA_BOT_MODEL=claude-sonnet-4-6
# Para OpenAI:
# OPENAI_API_KEY=sk-xxxxxxxx
# FIFA_BOT_MODEL=gpt-5.1

# Opcional (WhatsApp): si el bridge escucha en otra URL
# WHATSAPP_API_BASE_URL=http://localhost:8080/api
