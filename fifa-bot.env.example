# Copia este fichero a fifa-bot.env y rellena tus valores.
# fifa-bot.env NO debe subirse a ningún repo (contiene secretos).

# --- Telegram ---
# Uno o varios destinos separados por comas: tu chat_id, el de otra persona, o @canal.
TELEGRAM_CHAT_ID=TU_CHAT_ID_O_@canal
TELEGRAM_BOT_TOKEN=          # token de @BotFather

# --- LLM (Anthropic) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
# FIFA_BOT_MODEL=claude-sonnet-4-6

# --- YouTube (enlaces a los resúmenes de DAZN) ---
# API key de YouTube Data API v3 (Google Cloud). Si falta, se usa scraping como respaldo.
YOUTUBE_API_KEY=AIza...

# --- Resultados y partidos (football-data.org) ---
# API key gratuita de football-data.org. Si falta, el modelo busca los resultados por su cuenta.
FOOTBALL_DATA_KEY=

# --- Opcional ---
# FIFA_BOT_TODAY=2026-06-20   # genera la edición de un día pasado (para pruebas)
